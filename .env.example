# Clip Factory — credentials. Copy to ".env" and fill in what you use.
# Publishing works in DRY-RUN with none of these set, so you can start without them.
# Never commit the real .env. These values are read by skills/publish/publish.py.

# --- Mode ---
# "offline" = just make clips + content sheets + covers (no posting).
# "online"  = make clips AND post them. Toggle anytime: ./clip mode  (or ./clip online)
MODE=offline

# --- Free auto-posting (easiest, no TikTok audit needed) ---
# Upload-Post is a pre-audited partner: free tier ~10 uploads/month, cross-posts to
# TikTok/Reels/Shorts, uploads the file directly. Get a key at upload-post.com.
UPLOADPOST_API_KEY=your_uploadpost_api_key

# --- Option A: a pre-audited scheduler (easiest public posting for one person) ---
# Pick a provider (Post for Me, PostPeer, Zernio, Postproxy, ...), connect TikTok once,
# then paste its base URL + API key here.
SCHEDULER_BASE_URL=your_provider_base_url
SCHEDULER_API_KEY=your_provider_api_key

# --- Option B: your OWN TikTok app via the official Content Posting API ---
# Requires passing TikTok's app audit (scope video.publish) or posts stay private.
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token

# --- Composio: shared tool layer for both agents (Sheets/Drive/Notion/Slack/...) ---
# Get a key at composio.dev (dashboard -> API settings). See skills/composio/SKILL.md.
COMPOSIO_API_KEY=your_composio_api_key

# --- Operator ---
# Shown in the web UI header and used to attribute STATE.md/memory updates.
OPERATOR_NAME=
