c_select(){
  [ $# -eq 0 ] && { read -rp "Path to source video: " v; [ -z "${v:-}" ] && return 1; set -- "$v"; }
  run_spin "scanning for moments" "$PY" skills/clip-select/find_moments.py "$@"
}
c_publish(){ "$PY" skills/publish/publish.py "$@"; }
c_mem(){     "$PY" tools/memory.py "$@"; }
c_fx(){      "$PY" tools/fx.py "$@"; }
c_sort(){    [ $# -eq 0 ] && set -- auto; "$PY" tools/sort.py "$@"; }
c_ui(){      "$PY" tools/webui.py "$@"; }
c_content(){
  if [ $# -lt 1 ]; then
    echo 'usage: ./clip content <clip.mp4> --brief briefs/x.json --hook "what the clip shows"'
    return 1
  fi
  "$PY" tools/content.py "$@" && mem_log "content sheet for $1" "stage=content"
}
mem_log(){   "$PY" tools/memory.py log "$1" ${2:+--tags "$2"} 2>/dev/null || true; }
c_ingest(){  run_spin "ingesting inbox" "$PY" tools/ingest.py && mem_log "ingested inbox"; }

c_handoff(){  # snapshot everything the NEXT AI needs into HANDOFF.md
  {
    echo "# HANDOFF — read this first, then AGENT-PLAYBOOK.md"
    echo "_written $(date -Iseconds) by ./clip handoff_"
    echo
    "$PY" tools/memory.py recall
    echo
    echo "## repo state"
    git log --oneline -3 2>/dev/null | sed 's/^/- /'
    git status --short 2>/dev/null | sed 's/^/- /'
  } > HANDOFF.md
  mem_log "wrote HANDOFF.md for agent handoff"
  echo "wrote HANDOFF.md — point the other AI at it (it contains memory recall + repo state)."
}
c_cover(){
  if [ $# -lt 2 ]; then echo 'usage: ./clip cover <clip.mp4> "HOOK TEXT" [--pos top|center|bottom]'; return 1; fi
  "$PY" tools/make_cover.py "$@"
}
c_produce(){
  if [ $# -lt 1 ]; then
    echo 'usage: ./clip produce <cut.mp4> [--brief briefs/x.json] [--hook "TITLE"]'
    echo '       [--reframe crop|blur] [--grade vibrant|moody|none] [--no-captions] [--out f.mp4]'
    return 1
  fi
  "$PY" tools/produce.py "$@" && mem_log "produced: $*" "stage=produce"
}

c_demo(){  # zero-risk guided first run: synthesizes footage, runs the whole pipeline
  if [ "${1:-}" = "--clean" ]; then
    rm -rf work/demo out/demo briefs/demo.json work/_unsorted 2>/dev/null
    echo "demo artifacts removed."; return 0
  fi
  hdr "Demo — the full pipeline on synthetic footage (nothing real, nothing posted)"
  mkdir -p work/demo out/demo briefs knowledge
  seed_knowledge
  [ -f briefs/demo.json ] || cat > briefs/demo.json <<'EOF'
{"campaign":"demo","caption_template":"Watch the demo pipeline run end to end (AI-assisted edit)",
 "required_hashtags":["#demo"],"banned_phrases":["works fast"],"min_seconds":5,"max_seconds":60,
 "brand_color":"#FF6A2C","highlight_words":["demo","pipeline"],"ai_generated":true,
 "platforms":["tiktok"],"notes":"synthetic demo campaign — safe to delete (./clip demo --clean)"}
EOF
  [ -f work/demo/source.mp4 ] || run_spin "synthesize 20s source video" \
    ffmpeg -y -v error -f lavfi -i testsrc2=size=1280x720:rate=30:duration=20 \
      -f lavfi -i "sine=frequency=440:duration=20" \
      -c:v libx264 -preset veryfast -c:a aac -shortest work/demo/source.mp4
  run_spin "select: rank clip moments" "$PY" skills/clip-select/find_moments.py \
    work/demo/source.mp4 --count 3 --outdir work/demo/candidates >/dev/null || true
  c_cut work/demo/source.mp4 2 16 out/demo/clip_01.mp4 || return 1
  echo "  producing (watch the progress bar)…"
  c_produce out/demo/clip_01.mp4 --brief briefs/demo.json --hook 'DEMO\nPIPELINE' --out out/demo/clip_01_final.mp4 || return 1
  c_sheet out/demo/clip_01_final.mp4 out/demo/clip_01_sheet.png
  c_content out/demo/clip_01_final.mp4 --brief briefs/demo.json --hook "the demo pipeline running end to end"
  c_publish prepare --clip out/demo/clip_01_final.mp4 --brief briefs/demo.json --out out/demo/pkg.json >/dev/null \
    && c_publish publish --package out/demo/pkg.json | tail -3
  mem_log "ran ./clip demo" "stage=demo"
  hdr "Demo complete — everything the pipeline makes:"
  ls -1 out/demo | sed 's/^/   out\/demo\//'
  printf "\n  ${D}candidates:${X} work/demo/candidates/candidates.md\n"
  printf "  ${D}clean up:${X}   ./clip demo --clean\n"
  printf "  ${B}Next:${X} drop real campaign footage in ${B}inbox/${X} and run ${B}./clip ingest${X}\n\n"
}
c_sheet(){  # contact sheet: verify the footage matches the hook BEFORE shipping
  local src="${1:-}"; [ -z "$src" ] && { echo "usage: ./clip sheet <video> [out.png]"; return 1; }
  [ -f "$src" ] || { echo "not found: $src"; return 1; }
  local out="${2:-${src%.*}_sheet.png}"
  local dur; dur="$(ffprobe -v error -show_entries format=duration -of default=nw=1:nk=1 "$src")"
  local fps; fps="$(awk -v d="$dur" 'BEGIN{printf "%.4f", 9/(d>0?d:1)}')"
  ffmpeg -y -hide_banner -loglevel error -i "$src" \
    -vf "fps=$fps,scale=320:-2,tile=3x3:margin=4:padding=4" -frames:v 1 "$out" \
    && echo "wrote $out — check every panel supports the hook before publishing."
}

# ---------------- cut a clip ----------------
c_cut(){
  local src="${1:-}" start="${2:-}" end="${3:-}" out="${4:-}"
  if [ -z "$src" ] || [ -z "$start" ] || [ -z "$end" ]; then
    echo "usage: ./clip cut <source> <start> <end> [out.mp4]"
    echo "       times like 00:01:23 or plain seconds"; return 1; fi
  [ -f "$src" ] || { echo "not found: $src"; return 1; }
  [ -z "$out" ] && out="clip_$(printf '%s' "${start}-${end}" | tr -c 'A-Za-z0-9-' '_').mp4"
  # grep reads to EOF on purpose: with pipefail, grep -q's early exit SIGPIPEs
  # ffmpeg and fails the pipeline, silently demoting every cut to mpeg4
  local enc="libx264"; ffmpeg -hide_banner -encoders 2>/dev/null | grep -w libx264 >/dev/null || enc="mpeg4"
  local vargs="-c:v libx264 -preset veryfast -crf 20"; [ "$enc" = mpeg4 ] && vargs="-c:v mpeg4 -q:v 4"
  echo "cutting $src  $start → $end  (encoder: $enc)…"
  if ffmpeg -y -hide_banner -loglevel error -i "$src" -ss "$start" -to "$end" $vargs -c:a aac -movflags +faststart "$out"; then
    echo "wrote $out"; mem_log "cut $src $start-$end -> $out" "stage=cut"
  else echo "cut failed — check the timestamps."; return 1; fi
}

# ---------------- state ----------------
c_state(){
  [ -f STATE.md ] || { echo "no STATE.md — run ./clip setup"; return 1; }
  hdr "STATE.md  (the resumable source of truth)"
  sed 's/^/  /' STATE.md
  echo
}

# ---------------- dashboard ----------------
c_dashboard(){
  hdr "Dashboard"
  printf "  mode: ${B}%s${X}\n" "$(mode_label)"
  local camps n; camps="$(ls -1 work 2>/dev/null | grep -v '^_')"; n="$(printf '%s\n' "$camps" | grep -c .)"
  printf "  campaigns (%s): %s\n" "${n:-0}" "$(printf '%s ' $camps)"
  if [ -f knowledge/inbox-manifest.json ]; then
    local ing; ing="$(grep -c '"name"' knowledge/inbox-manifest.json 2>/dev/null || echo 0)"
    printf "  videos ingested: %s\n" "$ing"
  fi
  if [ -f knowledge/ledger.md ]; then
    local posts; posts="$(grep -cE '^\| 20[0-9][0-9]-' knowledge/ledger.md 2>/dev/null)"
    printf "  posts logged: %s\n" "$posts"
    if [ "${posts:-0}" -gt 0 ]; then
      echo; echo "  recent posts:"; grep -E '^\| 20[0-9][0-9]-' knowledge/ledger.md | tail -5 | sed 's/^/    /'
      echo; echo "  ${D}→ submit these URLs in Vyro; fill the views column as they grow.${X}"
    fi
  fi
  echo
}

# ---------------- settings ----------------
