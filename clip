#!/usr/bin/env bash
# clip — control center for the Clip Factory (Vyro clipping pipeline)
#   ./clip            interactive menu
#   ./clip <command>  run a command directly (see ./clip help)

set -uo pipefail
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$DIR"

# ---- colour: only on a real terminal, honouring the NO_COLOR standard.
# Palette is light/dark safe: orange 209 accent + bold default-fg; never
# yellow-on-default or dim-only for text that matters.
if [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
  G=$'\e[32m'; R=$'\e[31m'; Y=$'\e[38;5;209m'; C=$'\e[36m'; B=$'\e[1m'; D=$'\e[38;5;245m'; X=$'\e[0m'
else G=; R=; Y=; C=; B=; D=; X=; fi
UTF8=1; case "${LC_ALL:-${LANG:-}}" in *[Uu][Tt][Ff]*8*) ;; *) UTF8=0 ;; esac

ok(){  printf "  [${G}ok${X}] %s\n" "$1"; }
bad(){ printf "  [${R}!!${X}] %s\n" "$1"; [ -n "${2:-}" ] && printf "         ${D}→ %s${X}\n" "$2"; FAILS=$((FAILS+1)); }
opt(){ printf "  [${Y}--${X}] %s\n" "$1"; [ -n "${2:-}" ] && printf "         ${D}→ %s${X}\n" "$2"; }
hdr(){ printf "\n${B}%s${X}\n" "$1"; }
have(){ command -v "$1" >/dev/null 2>&1; }

PY="python3"; [ -x ".venv/bin/python" ] && PY=".venv/bin/python"

env_val(){ [ -f .env ] || return 0; grep -E "^$1=" .env 2>/dev/null | tail -1 | cut -d= -f2- | tr -d '"'"'"; }
is_set(){ local v="${1:-}"; [ -n "$v" ] && [[ "$v" != your_* ]] && [[ "$v" != *PLACEHOLDER* ]]; }

cur_mode(){ local m; m="$(env_val MODE)"; echo "${m:-offline}"; }
is_online(){ case "$(cur_mode)" in online|publish) return 0 ;; *) return 1 ;; esac; }
mode_label(){ is_online && printf "online" || printf "offline"; }

set_env(){  # set_env KEY VALUE — update or append a line in .env
  local k="$1" v="$2"
  [ -f .env ] || { [ -f .env.example ] && cp .env.example .env || touch .env; }
  if grep -qE "^$k=" .env; then sed -i.bak -E "s|^$k=.*|$k=$v|" .env && rm -f .env.bak
  else printf '%s=%s\n' "$k" "$v" >> .env; fi
}

auto_backend(){  # the free-first default for online mode
  is_set "$(env_val UPLOADPOST_API_KEY)" && { echo uploadpost; return; }
  is_set "$(env_val COMPOSIO_API_KEY)"   && { echo composio;   return; }
  is_set "$(env_val SCHEDULER_API_KEY)"  && { echo scheduler;  return; }
  echo queue
}

backend_summary(){
  local s="${D}—${X}" t="${D}—${X}" c="${D}—${X}" u="${D}—${X}"
  is_set "$(env_val UPLOADPOST_API_KEY)"  && u="${G}uploadpost${X}"
  is_set "$(env_val SCHEDULER_API_KEY)"   && s="${G}scheduler${X}"
  is_set "$(env_val TIKTOK_ACCESS_TOKEN)" && t="${G}tiktok-api${X}"
  is_set "$(env_val COMPOSIO_API_KEY)"    && c="${G}composio${X}"
  printf "%s · %s · %s · %s" "$u" "$s" "$t" "$c"
}

banner(){
  local cols="${COLUMNS:-$(tput cols 2>/dev/null || echo 80)}"
  case "$cols" in ''|*[!0-9]*) cols=80 ;; esac
  if [ "$UTF8" = 1 ] && [ "$cols" -ge 66 ]; then
    # ANSI Shadow wordmark, two stacked words (CLIP 27 cols, FACTORY 59 cols)
    local art=(
' ██████╗██╗     ██╗██████╗ '
'██╔════╝██║     ██║██╔══██╗'
'██║     ██║     ██║██████╔╝'
'██║     ██║     ██║██╔═══╝ '
'╚██████╗███████╗██║██║     '
' ╚═════╝╚══════╝╚═╝╚═╝     '
'███████╗ █████╗  ██████╗████████╗ ██████╗ ██████╗ ██╗   ██╗'
'██╔════╝██╔══██╗██╔════╝╚══██╔══╝██╔═══██╗██╔══██╗╚██╗ ██╔╝'
'█████╗  ███████║██║        ██║   ██║   ██║██████╔╝ ╚████╔╝ '
'██╔══╝  ██╔══██║██║        ██║   ██║   ██║██╔══██╗  ╚██╔╝  '
'██║     ██║  ██║╚██████╗   ██║   ╚██████╔╝██║  ██║   ██║   '
'╚═╝     ╚═╝  ╚═╝ ╚═════╝   ╚═╝    ╚═════╝ ╚═╝  ╚═╝   ╚═╝   '
    )
    local grad=(202 202 202 208 208 208 214 214 214 220 220 220) i
    for i in "${!art[@]}"; do
      if [ -n "$G" ]; then printf '  \e[38;5;%sm%s\e[0m\n' "${grad[$i]}" "${art[$i]}"
      else printf '  %s\n' "${art[$i]}"; fi
      if [ -t 1 ]; then sleep 0.03; fi
    done
    printf "  ${D}approved footage → clips that earn · v2.2${X}\n"
  elif [ "$UTF8" = 1 ]; then
    printf "  ${Y}${B}▶▶ CLIP FACTORY${X} ${D}— approved footage → clips that earn${X}\n"
  else
    printf "  ${Y}${B}>> CLIP FACTORY${X} ${D}-- approved footage -> clips that earn${X}\n"
  fi
}

# run a slow step behind a spinner (plain passthrough when piped)
run_spin(){  # run_spin "label" cmd [args...]
  local label="$1"; shift
  [ -t 1 ] || { "$@"; return $?; }
  local tmp t0 pid rc i=0 frames='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏'
  case "${LC_ALL:-${LANG:-}}" in *[Uu][Tt][Ff]*8*) ;; *) frames='|/-\|/-\|/' ;; esac
  tmp="$(mktemp)"; t0=$SECONDS
  "$@" >"$tmp" 2>&1 &
  pid=$!; printf '\e[?25l'
  while kill -0 "$pid" 2>/dev/null; do
    printf '\r  \e[38;5;209m%s\e[0m %s \e[2m%ss\e[0m ' "${frames:i%10:1}" "$label" "$((SECONDS-t0))"
    i=$((i+1)); sleep 0.08
  done
  wait "$pid"; rc=$?
  printf '\r\e[?25h\e[K'
  if [ $rc -eq 0 ]; then printf "  ${G}✓${X} %s ${D}(%ss)${X}\n" "$label" "$((SECONDS-t0))"
  else printf "  ${R}✗${X} %s ${D}(%ss)${X}\n" "$label" "$((SECONDS-t0))"; fi
  sed 's/^/    /' "$tmp"; rm -f "$tmp"; return $rc
}

pill(){  # pill "TEXT" bg-256  -> reverse-video badge ($G set = colors are on)
  if [ -n "$G" ]; then printf '\e[48;5;%s;38;5;16;1m %s \e[0m' "$2" "$1"; else printf '[%s]' "$1"; fi
}

# ---------------- doctor ----------------
c_doctor(){
  FAILS=0
  hdr "Environment check"
  hdr "Core (required)"
  if have python3; then ok "Python $(python3 -V 2>&1 | awk '{print $2}')"; else bad "python3 not found" "sudo dnf install -y python3 python3-pip"; fi
  if have ffmpeg;  then ok "ffmpeg $(ffmpeg -version 2>/dev/null | head -1 | awk '{print $3}')"; else bad "ffmpeg not found" "enable RPM Fusion, then: sudo dnf install -y ffmpeg"; fi
  if have ffprobe; then ok "ffprobe present"; else bad "ffprobe not found" "comes with the ffmpeg package"; fi
  [ -f skills/clip-select/find_moments.py ] && ok "clip-select skill" || bad "skills/clip-select/find_moments.py missing"
  [ -f skills/publish/publish.py ]          && ok "publish skill"     || bad "skills/publish/publish.py missing"
  [ -f tools/ingest.py ] && ok "ingest tool"  || bad "tools/ingest.py missing"
  [ -f tools/produce.py ] && ok "produce tool (9:16 + captions + grade)" || bad "tools/produce.py missing"
  [ -f tools/make_cover.py ] && ok "cover tool" || bad "tools/make_cover.py missing"
  [ -f tools/memory.py ] && ok "memory tool (./clip mem)" || bad "tools/memory.py missing"
  [ -f tools/content.py ] && ok "content tool" || bad "tools/content.py missing"
  [ -f tools/fx.py ] && ok "fx tool (fonts)"   || bad "tools/fx.py missing"
  [ -f tools/sort.py ] && ok "sort tool (auto-organize)" || bad "tools/sort.py missing"
  [ -f tools/webui.py ] && ok "web dashboard (./clip ui)" || bad "tools/webui.py missing"
  [ -f tests/smoke.sh ] && ok "smoke test (bash tests/smoke.sh)" || opt "tests/smoke.sh missing"
  { [ -f AGENT-PLAYBOOK.md ] && [ -f STATE.md ]; } && ok "agent playbook + STATE" || bad "AGENT-PLAYBOOK.md / STATE.md missing"
  if [ -f AGENTS.md ] && [ -f CLAUDE.md ]; then ok "dual-agent config (AGENTS.md + CLAUDE.md)"; else bad "AGENTS.md / CLAUDE.md missing" "./clip setup"; fi

  hdr "Optional"
  [ -d .venv ] && ok "python venv (.venv)" || opt "no .venv yet" "./clip setup"
  if have yt-dlp; then ok "yt-dlp (download approved source)"; else opt "yt-dlp not installed" "pipx install yt-dlp  (or: sudo dnf install -y yt-dlp)"; fi
  if "$PY" -c 'import faster_whisper' 2>/dev/null; then ok "faster-whisper (transcripts)"; else opt "faster-whisper not installed" "pip install faster-whisper — smarter clip picks + ingest notes"; fi
  if "$PY" -c 'import PIL' 2>/dev/null; then ok "Pillow (cover generator)"; else opt "Pillow not installed" "pip install pillow — needed for ./clip cover"; fi
  if "$PY" -c 'import composio' 2>/dev/null; then ok "composio SDK"; else opt "composio SDK not installed" "pip install composio — only for --via composio"; fi
  [ -f knowledge/ledger.md ] && ok "knowledge base / ledger" || opt "no ledger yet" "./clip setup"
  [ -d inbox ] && ok "inbox/ drop folder" || opt "no inbox/ yet" "./clip setup"

  hdr "Publishing"
  printf "  mode: ${B}%s${X}  %s\n" "$(mode_label)" "$(is_online && echo '(clips + posts)' || echo '(clips only — switch with ./clip online)')"
  if [ -f .env ]; then ok ".env present"; else opt "no .env yet" "cp .env.example .env (publish runs dry-run without it)"; fi
  is_set "$(env_val UPLOADPOST_API_KEY)"  && ok "Upload-Post key set (free auto-post)" || opt "Upload-Post not configured" "free tier at upload-post.com → UPLOADPOST_API_KEY (no audit, easiest)"
  is_set "$(env_val SCHEDULER_API_KEY)"   && ok "scheduler key set"     || opt "scheduler not configured" "add SCHEDULER_API_KEY to .env"
  is_set "$(env_val TIKTOK_ACCESS_TOKEN)" && ok "TikTok API token set"  || opt "TikTok official API not configured" "needs an audited app; add TIKTOK_ACCESS_TOKEN"
  is_set "$(env_val COMPOSIO_API_KEY)"    && ok "Composio key set"      || opt "Composio not configured" "add COMPOSIO_API_KEY + connect TikTok in the dashboard"

  hdr "Result"
  if [ "$FAILS" -eq 0 ]; then printf "  ${G}All required checks passed.${X}  Drop videos in ${B}inbox/${X}, then: ${B}./clip ingest${X}\n\n"
  else printf "  ${R}%s required item(s) need attention${X} — fix the [!!] lines above.\n\n" "$FAILS"; fi
}

# ---------------- setup ----------------
seed_knowledge(){  # idempotent knowledge-base seed
  [ -f knowledge/INDEX.md ] || printf '# Knowledge index\n\n- learnings.md — why clips won or lost\n- ledger.md — every shipped clip + its live URL + views\n- MEMORY.md — digest of the shared AI memory (./clip mem)\n' > knowledge/INDEX.md
  [ -f knowledge/learnings.md ] || printf '# Learnings\n\nOne line per clip that over- or under-performed, and why.\n' > knowledge/learnings.md
  [ -f knowledge/ledger.md ] || printf '# Ledger\n\n| date | campaign | clip | platform | url | views |\n|------|----------|------|----------|-----|-------|\n' > knowledge/ledger.md
}

c_setup(){
  hdr "Setup (safe, local only — downloads no remote code)"
  mkdir -p skills knowledge work out briefs inbox tools
  seed_knowledge
  [ -f inbox/README.txt ] || printf 'Drop your campaign videos here, then run ./clip ingest.\nOnly drop footage the campaign has approved.\n' > inbox/README.txt
  [ -f STATE.md ] || printf '# STATE\n\n## Mode\noffline\n\n## Next actions\n- Drop videos in inbox/ and run ./clip ingest.\n' > STATE.md
  if [ ! -d .venv ]; then echo "Creating python venv (.venv)…"; python3 -m venv .venv && echo "  done."; fi
  if [ ! -f .env ] && [ -f .env.example ]; then cp .env.example .env; echo "Created .env from template — add credentials when ready."; fi
  echo
  echo "Optional installs:"
  echo "  .venv/bin/pip install faster-whisper   # transcripts (smarter picks + ingest notes)"
  echo "  .venv/bin/pip install pillow           # needed for ./clip cover"
  echo "  .venv/bin/pip install composio requests# only if you use those publish backends"
  c_doctor
}

# ---------------- new campaign ----------------
c_new_campaign(){
  local name="${1:-}"
  [ -z "$name" ] && read -rp "Campaign name (e.g. beast-games): " name
  [ -z "$name" ] && { echo "no name given."; return 1; }
  name="$(echo "$name" | tr ' ' '-' | tr -cd 'A-Za-z0-9._-')"
  mkdir -p "work/$name" "out/$name" briefs
  local brief="briefs/$name.json"
  if [ -f "$brief" ]; then echo "brief already exists: $brief"; else
    cat > "$brief" <<EOF
{
  "campaign": "$name",
  "caption_template": "WRITE A SCROLL-STOPPING FIRST LINE HERE",
  "required_hashtags": ["#fyp"],
  "banned_phrases": [],
  "min_seconds": 0,
  "max_seconds": 0,
  "brand_color": "#FF6A2C",
  "highlight_words": [],
  "ai_generated": true,
  "is_branded": false,
  "disclosure": "",
  "video_url": "",
  "platforms": ["tiktok", "reels", "shorts"],
  "notes": "Paste the campaign's rules: allowed source, length limits, required tags/disclosures. banned_phrases = wording the brief forbids (e.g. health claims); min/max_seconds = length rules (0 = none); brand_color + highlight_words drive caption keyword highlighting in ./clip produce."
}
EOF
    echo "Created $brief — fill in the campaign's rules."
  fi
  echo "Put the APPROVED source video in: work/$name/"
}

