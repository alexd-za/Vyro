  hdr "Settings & credentials"
  echo "  .env: $([ -f .env ] && echo present || echo 'missing — run: ./clip setup')"
  printf "  mode: ${B}%s${X}  %s\n" "$(mode_label)" "$(is_online && echo '— makes clips AND posts them' || echo '— makes clips only (./clip online to post)')"
  echo
  printf "   %-26s %s\n" "Upload-Post (free auto)" "$(is_set "$(env_val UPLOADPOST_API_KEY)" && echo "${G}configured${X}" || echo "${D}— not set${X}")"
  printf "   %-26s %s\n" "Scheduler (publish)"  "$(is_set "$(env_val SCHEDULER_API_KEY)"   && echo "${G}configured${X}" || echo "${D}— not set${X}")"
  printf "   %-26s %s\n" "TikTok official API"   "$(is_set "$(env_val TIKTOK_ACCESS_TOKEN)" && echo "${G}configured${X}" || echo "${D}— not set${X}")"
