}

sync_state_mode(){  # keep STATE.md's Mode section matching .env
  [ -f STATE.md ] && sed -i "0,/^\*\*\(offline\|online\)\*\*/s//**$1**/" STATE.md 2>/dev/null || true
}

c_mode(){
  if [ -n "${1:-}" ]; then
    case "$1" in
      offline|clip)   set_env MODE offline; sync_state_mode offline; printf "mode → ${B}offline${X} (clips only)\n" ;;
      online|publish) set_env MODE online;  sync_state_mode online;  printf "mode → ${B}online${X} (clips + posts via %s)\n" "$(auto_backend)" ;;
      *) echo "usage: ./clip mode [offline|online]   (no arg = toggle)"; return 1 ;;
    esac
  else
    if is_online; then set_env MODE offline; sync_state_mode offline; printf "mode: online → ${B}offline${X} (clips only)\n"
    else set_env MODE online; sync_state_mode online; printf "mode: offline → ${B}online${X} (clips + posts via %s)\n" "$(auto_backend)"; fi
  fi
}

# ---------------- help ----------------
c_help(){
  banner
  cat <<EOF

${B}Hand this folder to an AI:${X} point it at ${B}AGENT-PLAYBOOK.md${X} and it runs the loop below.
Drop videos in ${B}inbox/${X}; state lives in ${B}STATE.md${X} so any session/AI resumes.

${B}Usage:${X}  ./clip [command]     (no command = interactive menu)

  ${B}install${X} [--yes]       install system deps (ffmpeg, python, extras) + setup
  ${B}demo${X} [--clean]        guided first run: full pipeline on synthetic footage
  ${B}setup${X}                 first-run: folders, venv, .env, agent config, doctor
  ${B}doctor${X}                check the environment and how to fix anything missing
  ${B}ingest${X}                inventory new videos dropped in inbox/
  ${B}sort${X} [auto|--yes]     auto-name campaigns + file dropped videos into them
  ${B}hashtags${X} <camp> --ask suggest hashtags (4 max) and save to the brief
  ${B}ui${X} [--port N]         open the local web dashboard (drag & drop videos)
  ${B}new-campaign${X} <name>   make work/ + out/ folders and a brief template
  ${B}select${X} <video> [..]   rank clip moments (--count --target --transcribe)
  ${B}cut${X} <vid> <in> <out>  cut one clip between two timestamps
  ${B}produce${X} <cut> [..]    finish a cut: 9:16 + captions + grade (--hook --brief)
  ${B}sheet${X} <video>         contact sheet — verify footage matches the hook
  ${B}cover${X} <clip> "HOOK"   generate a cover image (frame + hook text)
  ${B}content${X} <clip> [..]   draft title/captions/pinned comment from the brief
  ${B}fx${X} fonts              fetch open-licensed display fonts (better hooks)
  ${B}publish${X} <args>        prepare/publish a clip (dry-run unless --send)
  ${B}mem${X} <cmd>              shared AI memory: add / search / recall / digest
  ${B}handoff${X}               write HANDOFF.md so another AI resumes instantly
  ${B}mode${X} | offline | online   show/switch mode (offline = clips only)
  ${B}state${X}                 show STATE.md
  ${B}dashboard${X}             campaigns + posts logged
  ${B}config${X}                which publish backends are configured
  ${B}help${X}                  this message

${B}Pipeline:${X}  inbox → ingest → categorize → select → cut → produce → sheet (QA) → content sheet + cover → (post if online)
${D}Full walkthrough: GETTING-STARTED.md · Agent loop: AGENT-PLAYBOOK.md${X}
EOF
}

# ---------------- interactive prompts (menu) ----------------
i_select(){  read -rp "  source video: " v; [ -n "${v:-}" ] && c_select "$v"; }
i_cut(){     read -rp "  source: " s; read -rp "  start (mm:ss or sec): " a; read -rp "  end: " b; c_cut "${s:-}" "${a:-}" "${b:-}"; }
i_cover(){   read -rp "  clip (out/.../clip.mp4): " c; read -rp "  hook text: " hk; [ -n "${c:-}" ] && [ -n "${hk:-}" ] && c_cover "$c" "$hk"; }
i_produce(){ read -rp "  cut file: " c; read -rp "  hook title (optional): " hk; read -rp "  brief json (optional): " b
             [ -n "${c:-}" ] && c_produce "$c" ${hk:+--hook "$hk"} ${b:+--brief "$b"}; }
i_sheet(){   read -rp "  video: " v; [ -n "${v:-}" ] && c_sheet "$v"; }
i_prepare(){ read -rp "  cut file (out/.../clip.mp4): " c; read -rp "  brief json (briefs/x.json): " b; c_publish prepare --clip "${c:-}" ${b:+--brief "$b"}; }
i_publish(){
  read -rp "  package json [post_package.json]: " p; p="${p:-post_package.json}"
  local def; def="$(auto_backend)"
  read -rp "  via [$def] (queue/uploadpost/scheduler/official/composio): " v; v="${v:-$def}"
  echo "  ${D}(dry-run — review the output, then re-run with --send to publish)${X}"
  c_publish publish --package "$p" --via "$v"
}

# ---------------- menu ----------------
sect(){  # orange rule + uppercase gray label (labels are pure ASCII)
  local t r='──'; t="$(printf '%s' "$1" | tr '[:lower:]' '[:upper:]')"
  [ "$UTF8" = 1 ] || r='--'
  printf "\n  ${Y}%s${X} ${D}%s${X} ${Y}%s${X}\n" "$r" "$t" \
    "$(printf "${r:0:1}%.0s" $(seq 1 $((40-${#t}))))"
}
item(){ printf "   ${Y}${B}%s${X}  %-24s" "$1" "$2"; [ -n "${3:-}" ] && printf "${Y}${B}%s${X}  %-22s" "$3" "$4"; printf "\n"; }

menu_screen(){
  clear 2>/dev/null || true
  banner
  local MD
  if is_online; then MD="$(pill ONLINE 34)"
  else MD="$(pill OFFLINE 208)"; fi
  printf "\n  ${D}MODE${X}  %b   ${D}BACKENDS${X}  %b\n" "$MD" "$(backend_summary)"
  sect "agent / inbox"
  item i "Ingest inbox"           s "Show state"
  sect "create"
  item 3 "New campaign"           4 "Find clips"
  item 5 "Cut a clip"             p "Produce (9:16+captions)"
  item v "Verify (contact sheet)" 6 "Generate a cover"
  sect "publish"
  item 7 "Prepare a post"         8 "Publish / queue"
  sect "memory / handoff"
  item r "Recall memory"          o "Handoff to other AI"
  sect "track / config"
  item 9 "Dashboard"              2 "Doctor"
  item 1 "Setup"                  c "Settings"
  item d "Run the demo pipeline"
  item m "Toggle offline/online"  h "Help"
  printf "   ${Y}${B}q${X}  Quit\n"
}

menu(){
  while true; do
    menu_screen
    printf "\n  ${B}❯${X} "; read -r choice || break
    case "${choice:-}" in
      i|I) c_ingest ;;
      s|S) c_state ;;
      1) c_setup ;;
      2) c_doctor ;;
      3) c_new_campaign ;;
      4) i_select ;;
      5) i_cut ;;
      p|P) i_produce ;;
      v|V) i_sheet ;;
      6) i_cover ;;
      7) i_prepare ;;
      8) if is_online; then i_publish
         else printf "  ${Y}offline mode is on.${X} Clips are in ${B}out/<campaign>/${X}; switch with ${B}m${X} (or ${B}./clip online${X}) to post.\n"; fi ;;
      9) c_dashboard ;;
      r|R) c_mem recall ;;
      d|D) c_demo ;;
      o|O) c_handoff ;;
      m|M) c_mode ;;
      c|C) c_config ;;
      h|H|help|\?) c_help ;;
      q|Q|0|quit|exit) printf "  bye.\n"; return 0 ;;
      "") ;;
      *) printf "  ${Y}pick an option from the menu.${X}\n" ;;
    esac
    printf "\n  ${D}— Enter to return to the menu —${X} "; read -r _ || break
  done
}

# ---------------- dispatch ----------------
case "${1:-menu}" in
  menu)              menu ;;
  install)           shift; bash install.sh "$@" ;;
  demo)              shift; c_demo "$@" ;;
  setup)             c_setup ;;
  doctor)            c_doctor ;;
  ingest)            c_ingest ;;
  new-campaign|nc)   shift; c_new_campaign "$@" ;;
  select|clips)      shift; c_select "$@" ;;
  cut)               shift; c_cut "$@" ;;
  produce)           shift; c_produce "$@" ;;
  sheet)             shift; c_sheet "$@" ;;
  cover)             shift; c_cover "$@" ;;
  publish)           shift; c_publish "$@" ;;
  mem|memory)        shift; c_mem "$@" ;;
  sort)              shift; c_sort "$@" ;;
  hashtags)          shift; c_sort hashtags "$@" ;;
  ui|web)            shift; c_ui "$@" ;;
  fx)                shift; c_fx "$@" ;;
  content)           shift; c_content "$@" ;;
  handoff)           c_handoff ;;
  mode)              shift; c_mode "$@" ;;
  offline)           c_mode offline ;;
  online)            c_mode online ;;
  state)             c_state ;;
  dashboard|status)  c_dashboard ;;
  config|settings)   c_config ;;
  help|-h|--help)    c_help ;;
  *) printf "unknown command: %s\n\n" "$1"; c_help; exit 1 ;;
esac
